# ---- Directus connection ----
DIRECTUS_URL=https://your-directus.example.com
DIRECTUS_TOKEN=replace-with-directus-static-token

# ---- MCP transport ----
# Canonical values: `streamable-http` (default, production) or `stdio` (local debug).
# The legacy alias `http` is accepted and canonicalised to `streamable-http`.
MCP_TRANSPORT=streamable-http
MCP_HTTP_PORT=3333

# ---- HTTP server bind / routing ----
# Network interface to bind. Use 127.0.0.1 for local-only, 0.0.0.0 (default) for Docker.
MCP_BIND_HOST=0.0.0.0
# HTTP path that serves MCP. Default /mcp. /healthz is always available for liveness probes.
MCP_ENDPOINT_PATH=/mcp

# ---- HTTP auth (applies to streamable-http transport only; stdio is exempt) ----
MCP_REQUIRE_AUTH=true
MCP_AUTH_TOKEN=replace-with-random-token

# ---- DNS rebinding / CSRF protection (optional, empty = allow any) ----
# Comma-separated allowlist of allowed Origin header values.
# Example: https://chat.example.com,https://internal.example.com
MCP_ALLOWED_ORIGINS=
# Comma-separated allowlist of allowed Host header values (lowercased).
# Example: mcp.example.com,localhost:3333
MCP_ALLOWED_HOSTS=

# ---- Collection guards ----
# Empty = allow any non-system collection. Comma-separated list to restrict.
DIRECTUS_ALLOWED_COLLECTIONS=
DIRECTUS_DENIED_COLLECTION_PREFIXES=directus_
DIRECTUS_ALLOW_DELETE=false
DIRECTUS_ALLOW_SCHEMA_WRITE=false

# ---- Mutation safety ----
MUTATION_DRY_RUN_DEFAULT=true
# When true, every update_item / batch_update_items call MUST carry a non-empty
# `verify` object. update_items_same_data is refused (it has no per-key verify).
MUTATION_REQUIRE_VERIFY=true
MUTATION_MAX_BATCH_SIZE=100

# ---- Read safety ----
READ_DEFAULT_LIMIT=50
READ_MAX_LIMIT=500
ALLOW_WILDCARD_FIELDS=false

# ---- Schema cache ----
SCHEMA_CACHE_TTL_SECONDS=300

# ---- Verify behavior ----
VERIFY_CASE_INSENSITIVE=false

# ---- Text-output limits (content.text in MCP responses) ----
# These cap how much real result data goes into the human-readable text
# part of each tool response (so the LLM can see it without LibreChat
# having to surface structuredContent). Token-bloat protection.
SCHEMA_TEXT_MAX_FIELDS=80
READ_TEXT_MAX_ROWS=10
READ_TEXT_MAX_CHARS=12000

# ---- Compact full text-output limits ----
# These settings control output_mode="compact_full" responses.
# compact_full is used when the LLM needs to see the full short list in content.text,
# for example listing 49 records without LibreChat hiding structuredContent.
#
# READ_TEXT_MAX_ROWS / READ_TEXT_MAX_CHARS still control preview-mode output.
# READ_COMPACT_* controls full compact list output.

# Max number of records that compact_full may render into content.text.
# Useful for short list answers. If a result has more rows, the tool marks
# TEXT_RECORDS_COMPLETE=false and SAFE_FOR_FULL_LIST_ANSWER=false.
READ_COMPACT_FULL_MAX_ROWS=200

# Max characters shown for a single field/cell in compact_full.
# Longer values are treated as long fields and omitted/shortened so ai_info,
# descriptions, prompts, messages, large JSON, etc. do not bloat the LLM context.
READ_COMPACT_CELL_MAX_CHARS=160

# Max total characters allowed in compact_full content.text.
# If the rendered text exceeds this, the tool marks the output as incomplete:
# TRUNCATED_FOR_TEXT=true and SAFE_FOR_FULL_LIST_ANSWER=false.
READ_COMPACT_TEXT_MAX_CHARS=30000

# Compact output format.
# "lines" is recommended for LibreChat and smaller models because it is easier
# to parse than markdown tables.
# Supported: lines, table
READ_COMPACT_FORMAT=lines

# ---- Dry-run approval plan flow ----
# Legacy fallback. If operation-specific settings below are empty/unset,
# they inherit this value.
APPLY_REQUIRES_PLAN=true

# Operation-specific plan policy. Set CREATE_REQUIRES_PLAN=false to allow
# direct create writes while update/delete/bulk still require dry-run approval.
CREATE_REQUIRES_PLAN=false
UPDATE_REQUIRES_PLAN=true
DELETE_REQUIRES_PLAN=true
BULK_REQUIRES_PLAN=true
UPDATE_BY_QUERY_REQUIRES_PLAN=true

# Plan store backend: file (default, production) or memory (tests only).
PLAN_STORE=file
# Directory for file-based plan store. Plans contain sensitive data
# (field values being written). File permissions are 0600.
PLAN_STORE_DIR=/tmp/directus-safe-mcp-plans
# Plan TTL in seconds (default 900 = 15 minutes).
PLAN_TTL_SECONDS=900
# Max plan payload size in bytes (default 1 MB).
PLAN_MAX_BYTES=1048576

# ---- Logging ----
LOG_LEVEL=info
